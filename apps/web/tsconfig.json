{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@quickhelp/tool-kit": [
        "../../packages/tool-kit/src/index.ts"
      ],
      "@quickhelp/agent-sdk": [
        "../../packages/agent-sdk/src/index.ts"
      ],
      "@quickhelp/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@quickhelp/seo": [
        "../../packages/seo/src/index.ts"
      ],
      "@quickhelp/analytics": [
        "../../packages/analytics/src/index.ts"
      ],
      "@quickhelp/tools-jwt-decoder": [
        "../../packages/tools/jwt-decoder/src/index.ts"
      ],
      "@quickhelp/tools-json-formatter": [
        "../../packages/tools/json-formatter/src/index.ts"
      ]
    },
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
