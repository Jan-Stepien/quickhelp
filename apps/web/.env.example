# App URL (used in metadata and sitemap)
NEXT_PUBLIC_APP_URL=https://quickhelp.dev

# Cloudflare Web Analytics — set to enable analytics (gated on user consent)
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# AdSense — set both to enable real ads (gated on user advertising consent)
# Default is off; staging/local stays on house-ads
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1421468575513438
