{
  "name": "quickhelp-mcp",
  "version": "1.0.0",
  "description": "MCP server for quickhelp.dev — 15 free developer tools (JWT decoder, image converter, Base64, hash generator, UUID, JSON formatter, and more) available to any MCP-compatible AI agent.",
  "keywords": ["mcp", "model-context-protocol", "developer-tools", "jwt", "json", "image-converter", "base64", "uuid", "hash", "ai-tools", "claude"],
  "homepage": "https://quickhelp.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jan-Stepien/quickhelp"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "quickhelp-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "node --import tsx/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@quickhelp/agent-sdk": "workspace:*",
    "@quickhelp/tool-kit": "workspace:*",
    "@quickhelp/tools-image-converter": "workspace:*",
    "@quickhelp/tools-image-resizer": "workspace:*",
    "@quickhelp/tools-json-formatter": "workspace:*",
    "@quickhelp/tools-jwt-decoder": "workspace:*",
    "@quickhelp/tools-base64": "workspace:*",
    "@quickhelp/tools-hash-generator": "workspace:*",
    "@quickhelp/tools-timestamp-converter": "workspace:*",
    "@quickhelp/tools-json-to-csv": "workspace:*",
    "@quickhelp/tools-text-case-converter": "workspace:*",
    "@quickhelp/tools-uuid-generator": "workspace:*",
    "@quickhelp/tools-url-encoder": "workspace:*",
    "@quickhelp/tools-color-converter": "workspace:*",
    "@quickhelp/tools-number-base-converter": "workspace:*",
    "@quickhelp/tools-lcov-viewer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.2"
  }
}
